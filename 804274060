local function teleportEatEgg(egg)
    local myRoot = getMyRoot()
    if not myRoot then return end
    
    pcall(function()
        myRoot.CFrame = CFrame.new(egg.position + Vector3.new(0, 2, 0))
    end)
    
    pcall(function()
        if egg.instance:IsA("Model") then
            for _, part in ipairs(egg.instance:GetDescendants()) do
                if part:IsA("BasePart") then
                    pcall(function()
                        firetouchinterest(myRoot, part, 0)
                        firetouchinterest(myRoot, part, 1)
                    end)
                end
            end
        elseif egg.instance:IsA("BasePart") then
            firetouchinterest(myRoot, egg.instance, 0)
            firetouchinterest(myRoot, egg.instance, 1)
        end
    end)
end

local function fastCollectLoop()
    while fastRunning do
        local myRoot = getMyRoot()
        if myRoot then
            local eggs = getEggs()
            if #eggs > 0 then
                table.sort(eggs, function(a, b)
                    return (myRoot.Position - a.position).Magnitude < (myRoot.Position - b.position).Magnitude
                end)
                teleportEatEgg(eggs[1])
            end
        end
        task.wait(fastInterval)
    end
end

