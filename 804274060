-- ==================== 公共函数 ====================
local function getHRP()
    local char = player.Character
    if not char then return nil end
    for _, v in ipairs(char:GetChildren()) do
        if v.Name == "HumanoidRootPart" or v.Name == "RootPart" then
            return v
        end
    end
    return char.PrimaryPart
end

local function getRootPart(char)
    if not char then return nil end
    local r = char:FindFirstChild("RootPart")
    if r and r:IsA("BasePart") then return r end
    r = char:FindFirstChild("HumanoidRootPart")
    if r and r:IsA("BasePart") then return r end
    r = char.PrimaryPart
    if r and r:IsA("BasePart") then return r end
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("BasePart") and v.Name ~= "FoodCollectionRadius" and v.Name ~= "CameraSubject" then
            return v
        end
    end
    return nil
end

local function getMyRoot()
    return getRootPart(player.Character)
end

local function isEgg(instance)
    if not instance then return false end
    local name = instance.Name:lower()
    local keywords = {"egg", "蛋", "dinoegg", "dino_egg", "nest"}
    for _, kw in ipairs(keywords) do
        if name:find(kw) then
            return true
        end
    end
    if CollectionService:HasTag(instance, "Egg") then
        return true
    end
    return false
end

local function getEggs()
    local eggs = {}
    for _, obj in ipairs(CollectionService:GetTagged("Food")) do
        if isEgg(obj) and obj.Parent then
            local ok, pos = pcall(function()
                if obj:IsA("Model") then return obj:GetPivot().Position
                elseif obj:IsA("BasePart") then return obj.Position end
            end)
            if ok and pos then
                table.insert(eggs, {instance = obj, position = pos})
            end
        end
    end
    for _, obj in ipairs(CollectionService:GetTagged("Egg")) do
        if obj.Parent then
            local ok, pos = pcall(function()
                if obj:IsA("Model") then return obj:GetPivot().Position
                elseif obj:IsA("BasePart") then return obj.Position end
            end)
            if ok and pos then
                table.insert(eggs, {instance = obj, position = pos})
            end
        end
    end
    return eggs
end

-- ==================== 自动捡恐龙蛋（慢 - 平移）====================
local SlowTab = Window:Tab({
    Title = "自动捡恐龙蛋（慢）",
    Icon = "turtle",
    IconColor = Color3.fromHex("#90EE90"),
    IconShape = "Square",
    Border = true
})

local slowRunning = false
local slowSpeed = 100
local slowMoverConn = nil

local function getClosestEggSlow()
    local hrp = getHRP()
    if not hrp then return nil end
    local best, bestDist = nil, math.huge

    for _, food in CollectionService:GetTagged("Food") do
        if not food or not food.Parent then continue end
        if isEgg(food) then
            local ok, pos = pcall(function()
                if food:IsA("Model") then return food:GetPivot().Position
                elseif food:IsA("BasePart") then return food.Position end
            end)
            if ok and pos then
                local d = (hrp.Position - pos).Magnitude
                if d < bestDist then
                    bestDist = d
                    best = {instance = food, position = pos}
                end
            end
        end
    end

    for _, egg in CollectionService:GetTagged("Egg") do
        if not egg or not egg.Parent then continue end
        local ok, pos = pcall(function()
            if egg:IsA("Model") then return egg:GetPivot().Position
            elseif egg:IsA("BasePart") then return egg.Position end
        end)
        if ok and pos then
            local d = (hrp.Position - pos).Magnitude
            if d < bestDist then
                bestDist = d
                best = {instance = egg, position = pos}
            end
        end
    end

    return best
end

local function stopSlowMover()
    if slowMoverConn then slowMoverConn:Disconnect(); slowMoverConn = nil end
end

local function moveToSlow(targetPos)
    local reached = false
    stopSlowMover()
    slowMoverConn = RunService.Heartbeat:Connect(function(dt)
        local hrp = getHRP()
        if not hrp or not slowRunning then reached = true; stopSlowMover(); return end
        local diff = targetPos - hrp.Position
        local dist = diff.Magnitude
        if dist < 2 then reached = true; stopSlowMover(); return end
        local step = math.min(slowSpeed * dt, dist)
        hrp.CFrame = CFrame.new(hrp.Position + diff.Unit * step)
    end)
    while not reached do task.wait(0.05) end
end

local function slowCollectLoop()
    while slowRunning do
        local egg = getClosestEggSlow()
        if egg then
            moveToSlow(egg.position)
        end
        task.wait(0.2)
    end
end

