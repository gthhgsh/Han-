local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualInputManager = game:GetService("VirtualInputManager")

local eating = false
local eatInterval = 0.3
local safeMode = true
local autoBite = true
local spawnProtectRadius = 80
local minDistance = 10
local lastPositions = {}

local function isAlive(char)
    if not char then return false end
    local root = getRootPart(char)
    if not root or not root.Parent then return false end
    if not char:IsDescendantOf(Workspace) then return false end
    return true
end

local function getSize(char)
    local root = getRootPart(char)
    if not root then return 0 end
    return root.Size.Y
end

local function getSpawnPositions()
    local spawns = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("SpawnLocation") then
            table.insert(spawns, obj.Position)
        end
    end
    if #spawns == 0 then
        local myRoot = getMyRoot()
        if myRoot then
            table.insert(spawns, myRoot.Position)
        end
    end
    return spawns
end

local function isInSpawnProtection(target)
    local spawns = getSpawnPositions()
    for _, spawnPos in ipairs(spawns) do
        if (target.pos - spawnPos).Magnitude < spawnProtectRadius then
            return true
        end
    end
    return false
end

local function isMoving(target)
    local key = target.name
    local currentPos = target.pos
    local lastPos = lastPositions[key]
    
    if lastPos then
        local moved = (currentPos - lastPos).Magnitude
        lastPositions[key] = currentPos
        return moved > 0.5
    else
        lastPositions[key] = currentPos
        return true
    end
end

local function cleanLastPositions(targets)
    local validNames = {}
    for _, t in ipairs(targets) do
        validNames[t.name] = true
    end
    for name in pairs(lastPositions) do
        if not validNames[name] then
            lastPositions[name] = nil
        end
    end
end

local function getEnemyPlayers()
    local list = {}
    local myChar = player.Character
    local myRoot = getMyRoot()
    local myPos = myRoot and myRoot.Position or Vector3.zero
    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character and plr.Character ~= myChar then
            local char = plr.Character
            if isAlive(char) then
                local root = getRootPart(char)
                if root then
                    local pos = root.Position
                    local dist = (pos - myPos).Magnitude
                    
                    table.insert(list, {
                        name = plr.Name,
                        char = char,
                        root = root,
                        pos = pos,
                        size = getSize(char),
                        dist = dist
                    })
                end
            end
        end
    end
    
    cleanLastPositions(list)
    return list
end

local detectedEvents = nil
local function detectBiteEvents()
    if detectedEvents then return detectedEvents end
    detectedEvents = {}
    
    local function scan(obj, depth)
        if depth > 6 then return end
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                local name = child.Name:lower()
                local full = child:GetFullName():lower()
                if name:find("bite") or name:find("eat") or name:find("attack") or name:find("damage") or 
                   name:find("combat") or name:find("interact") or name:find("action") or
                   name:find("feed") or name:find("consume") then
                    table.insert(detectedEvents, child)
                elseif full:find("knit") and (name:find("rp") or name:find("re") or name:find("rf")) then
                    table.insert(detectedEvents, child)
                end
            end
            scan(child, depth + 1)
        end
    end
    
    scan(ReplicatedStorage, 0)
    return detectedEvents
end

local function performBite(target)
    local myRoot = getMyRoot()
    if not myRoot then return end
    
    if autoBite then
        pcall(function()
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
            task.wait(0.05)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        end)
        pcall(function()
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
            task.wait(0.05)
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
        end)
    end
    
    pcall(function()
        firetouchinterest(myRoot, target.root, 0)
        firetouchinterest(myRoot, target.root, 1)
    end)
    pcall(function()
        for _, part in ipairs(target.char:GetDescendants()) do
            if part:IsA("BasePart") then
                pcall(function()
                    firetouchinterest(myRoot, part, 0)
                    firetouchinterest(myRoot, part, 1)
                end)
            end
        end
    end)
    
    local events = detectBiteEvents()
    for _, ev in ipairs(events) do
        pcall(function()
            if ev:IsA("RemoteEvent") then
                ev:FireServer(target.char)
                ev:FireServer(target.root)
                ev:FireServer(target.root.Position)
                ev:FireServer(target.char, target.root.Position)
                ev:FireServer("Bite", target.char)
                ev:FireServer("Attack", target.char)
            elseif ev:IsA("RemoteFunction") then
                ev:InvokeServer(target.char)
            end
        end)
    end
end

local function teleportEat(target)
    local myRoot = getMyRoot()
    if not myRoot then return end
    if not target or not target.root or not target.root.Parent then return end
    
    pcall(function()
        myRoot.CFrame = target.root.CFrame
    end)
    
    performBite(target)
end

local lastNotify = 0

local function eatLoop()
    while eating do
        local myRoot = getMyRoot()
        if myRoot then
            local targets = getEnemyPlayers()
            local mySize = getSize(player.Character)
            
            local valid = {}
            for _, t in ipairs(targets) do
                if isInSpawnProtection(t) then
                    continue
                end
                
                if t.dist < minDistance then
                    continue
                end
                
                if not isMoving(t) then
                    continue
                end
                
                if safeMode then
                    if t.size < mySize then
                        table.insert(valid, t)
                    end
                else
                    table.insert(valid, t)
                end
            end
            
            if #valid > 0 then
                table.sort(valid, function(a, b)
                    return a.dist < b.dist
                end)
                
                local closest = valid[1]
                
                local now = tick()
                if now - lastNotify > 3 then
                    lastNotify = now
                    WindUI:Notify({
                        Title = "锁定: " .. closest.name, 
                        Content = "距离:" .. math.floor(closest.dist) .. " | 体型:" .. string.format("%.1f", closest.size), 
                        Duration = 2
                    })
                end
                
                teleportEat(closest)
            else
                if tick() - lastNotify > 5 then
                    lastNotify = tick()
                    WindUI:Notify({Title = "扫描中", Content = "附近没有可吃目标", Duration = 2})
                end
            end
        end
        task.wait(eatInterval)
    end
end

